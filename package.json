{
  "private": true,
  "name": "templatewing",
  "version": "2.7.1",
  "description": "Thunderbird add-on: manage and insert email templates with attachments",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:ui": "playwright test --config=playwright.config.mjs",
    "lint": "node scripts/lint-locales.js",
    "format:check": "npx prettier --check \"**/*.{js,css,html,json}\" --ignore-path .gitignore",
    "build:xpi": "node scripts/build-xpi.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
